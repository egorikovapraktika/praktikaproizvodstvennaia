<Window x:Class="LibrarySystem.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Библиотечная система" Height="650" Width="700"
        WindowStartupLocation="CenterScreen"
        AllowsTransparency="True"
        WindowStyle="None"
        Background="Transparent">
    
    <Border CornerRadius="20" Background="White" BorderBrush="#2C3E50" BorderThickness="2">
        <Grid Margin="50">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Button x:Name="btnClose" Content="✕" Width="35" Height="35" 
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Background="Transparent" Foreground="#E74C3C"
                    FontSize="18" FontWeight="Bold"
                    Click="BtnClose_Click" Cursor="Hand"/>

            <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,20,0,20">
                <TextBlock Text="📚" FontSize="56" HorizontalAlignment="Center"/>
                <TextBlock Text="БИБЛИОТЕЧНАЯ СИСТЕМА" 
                           FontSize="24" FontWeight="Bold" 
                           Foreground="#2C3E50"
                           HorizontalAlignment="Center" Margin="0,10,0,0"/>
                <TextBlock Text="Учёт и выдача книг" 
                           FontSize="13" Foreground="#7F8C8D"
                           HorizontalAlignment="Center" Margin="0,5,0,0"/>
            </StackPanel>

            <TextBlock Grid.Row="1" Text="Email (логин)" FontSize="14" Foreground="#34495E" Margin="0,5,0,3"/>
            <TextBox x:Name="txtLogin" Grid.Row="2" FontSize="14" Height="38" Padding="12,10" Margin="0,0,0,15"/>

            <TextBlock Grid.Row="3" Text="Телефон (пароль)" FontSize="14" Foreground="#34495E" Margin="0,5,0,3"/>
            <PasswordBox x:Name="txtPassword" Grid.Row="4" FontSize="14" Height="38" Padding="12,10" Margin="0,0,0,25"/>

            <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                <Button x:Name="btnLogin" Content="ВОЙТИ" Width="140" Height="45" 
                        FontSize="15" FontWeight="Bold"
                        Background="#3498DB" Foreground="White" 
                        Click="BtnLogin_Click" Cursor="Hand" Margin="0,0,15,0"/>
                <Button x:Name="btnRegister" Content="РЕГИСТРАЦИЯ" Width="140" Height="45" 
                        FontSize="15" FontWeight="Bold"
                        Background="#2ECC71" Foreground="White" 
                        Click="BtnRegister_Click" Cursor="Hand"/>
            </StackPanel>
            
            <Border Grid.Row="6" Background="#ECF0F1" CornerRadius="10" Padding="10" Margin="0,25,0,0">
                <TextBlock Text="👑 Администратор: admin / admin123" 
                           FontSize="12" Foreground="#7F8C8D"
                           HorizontalAlignment="Center"/>
            </Border>
        </Grid>
    </Border>
</Window>