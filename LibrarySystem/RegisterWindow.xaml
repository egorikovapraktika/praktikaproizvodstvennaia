<Window x:Class="LibrarySystem.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Регистрация" Height="700" Width="580"
        WindowStartupLocation="CenterScreen"
        AllowsTransparency="True"
        WindowStyle="None"
        Background="Transparent">
    
    <Border CornerRadius="20" Background="White" BorderBrush="#2C3E50" BorderThickness="2">
        <Grid Margin="40">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Button x:Name="btnClose" Content="✕" Width="35" Height="35" 
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Background="Transparent" Foreground="#E74C3C"
                    FontSize="18" FontWeight="Bold"
                    Click="BtnClose_Click" Cursor="Hand"/>

            <TextBlock Grid.Row="0" Text="📝 РЕГИСТРАЦИЯ" 
                       FontSize="24" FontWeight="Bold" 
                       Foreground="#2C3E50"
                       HorizontalAlignment="Center" Margin="0,15,0,20"/>

            <TextBlock Grid.Row="1" Text="Фамилия" FontSize="13" Foreground="#34495E" Margin="0,3"/>
            <TextBox x:Name="txtLastName" Grid.Row="2" FontSize="13" Height="35" Padding="10" Margin="0,0,0,12"/>

            <TextBlock Grid.Row="3" Text="Имя" FontSize="13" Foreground="#34495E" Margin="0,3"/>
            <TextBox x:Name="txtFirstName" Grid.Row="4" FontSize="13" Height="35" Padding="10" Margin="0,0,0,12"/>

            <TextBlock Grid.Row="5" Text="Email (логин)" FontSize="13" Foreground="#34495E" Margin="0,3"/>
            <TextBox x:Name="txtEmail" Grid.Row="6" FontSize="13" Height="35" Padding="10" Margin="0,0,0,12"/>

            <TextBlock Grid.Row="7" Text="Телефон (пароль)" FontSize="13" Foreground="#34495E" Margin="0,3"/>
            <TextBox x:Name="txtPhone" Grid.Row="8" FontSize="13" Height="35" Padding="10" Margin="0,0,0,20"/>

            <StackPanel Grid.Row="9" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
                <Button x:Name="btnSave" Content="ЗАРЕГИСТРИРОВАТЬСЯ" Width="180" Height="45" 
                        FontSize="13" FontWeight="Bold"
                        Background="#2ECC71" Foreground="White" Click="BtnSave_Click" Cursor="Hand" Margin="0,0,15,0"/>
                <Button x:Name="btnCancel" Content="ОТМЕНА" Width="120" Height="45" 
                        FontSize="13" FontWeight="Bold"
                        Background="#95A5A6" Foreground="White" Click="BtnCancel_Click" Cursor="Hand"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>