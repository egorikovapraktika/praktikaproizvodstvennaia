<Window x:Class="LibrarySystem.UserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Читательская панель" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#F0F3F5"
        WindowStyle="SingleBorderWindow">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2C3E50" CornerRadius="15" Padding="20">
            <Grid>
                <TextBlock Text="📚 БИБЛИОТЕЧНАЯ СИСТЕМА" FontSize="22" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <TextBlock x:Name="txtUserName" Text="Читатель" FontSize="16" Foreground="#BDC3C7" VerticalAlignment="Center" Margin="0,0,20,0"/>
                    <Button x:Name="btnLogout" Content="🚪 ВЫХОД" Background="#E74C3C" Foreground="White" 
                            Width="120" Height="40" FontSize="14" FontWeight="Bold" Click="BtnLogout_Click" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="White" CornerRadius="15" Padding="20" Margin="0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <Border Grid.Column="0" Background="#E8F8F5" CornerRadius="15" Padding="15" Margin="10">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="📖" FontSize="36" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="txtTotalBooks" Text="0" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="всего книг" FontSize="14" Foreground="#7F8C8D" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                
                <Border Grid.Column="1" Background="#FEF9E7" CornerRadius="15" Padding="15" Margin="10">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="📋" FontSize="36" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="txtMyBooks" Text="0" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="у меня на руках" FontSize="14" Foreground="#7F8C8D" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                
                <Border Grid.Column="2" Background="#FDEDEC" CornerRadius="15" Padding="15" Margin="10">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="⏰" FontSize="36" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="txtOverdue" Text="0" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="просроченных" FontSize="14" Foreground="#7F8C8D" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <TabControl Grid.Row="2" Margin="0,0,0,20" FontSize="14">
            <TabItem Header="📚 ДОСТУПНЫЕ КНИГИ" Height="35">
                <DataGrid x:Name="dgBooks" AutoGenerateColumns="True" IsReadOnly="True" 
                          SelectionMode="Single" Background="White" FontSize="13" 
                          RowHeight="35" Margin="5"/>
            </TabItem>
            <TabItem Header="📋 МОИ КНИГИ" Height="35">
                <DataGrid x:Name="dgMyBooks" AutoGenerateColumns="True" IsReadOnly="True" 
                          Background="White" FontSize="13" RowHeight="35" Margin="5"/>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button x:Name="btnBorrow" Content="📖 ЗАБРОНИРОВАТЬ И ВЗЯТЬ" Width="240" Height="55" 
                    FontSize="15" FontWeight="Bold"
                    Background="#3498DB" Foreground="White" Click="BtnBorrow_Click" Cursor="Hand" Margin="0,0,10,0"/>
            <Button x:Name="btnRefresh" Content="🔄 ОБНОВИТЬ" Width="160" Height="55" 
                    FontSize="15" FontWeight="Bold"
                    Background="#95A5A6" Foreground="White" Click="BtnRefresh_Click" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>