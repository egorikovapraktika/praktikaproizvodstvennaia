<Window x:Class="LibrarySystem.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Административная панель" Height="800" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#F0F3F5"
        WindowStyle="SingleBorderWindow">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#8E44AD" CornerRadius="15" Padding="20">
            <Grid>
                <TextBlock Text="👑 АДМИНИСТРАТОРСКАЯ ПАНЕЛЬ" FontSize="22" FontWeight="Bold" Foreground="White"/>
                <Button x:Name="btnLogout" Content="🚪 ВЫХОД" Background="#E74C3C" Foreground="White" 
                        Width="120" Height="40" FontSize="14" FontWeight="Bold"
                        HorizontalAlignment="Right" Click="BtnLogout_Click" Cursor="Hand"/>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="White" CornerRadius="15" Padding="20" Margin="0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <Border Grid.Column="0" Background="#E8F8F5" CornerRadius="15" Padding="15" Margin="10">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="📚" FontSize="36"/>
                        <TextBlock x:Name="txtTotalBooks" Text="0" FontSize="28" FontWeight="Bold"/>
                        <TextBlock Text="всего книг" FontSize="14" Foreground="#7F8C8D"/>
                    </StackPanel>
                </Border>
                
                <Border Grid.Column="1" Background="#FEF9E7" CornerRadius="15" Padding="15" Margin="10">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="👥" FontSize="36"/>
                        <TextBlock x:Name="txtTotalReaders" Text="0" FontSize="28" FontWeight="Bold"/>
                        <TextBlock Text="читателей" FontSize="14" Foreground="#7F8C8D"/>
                    </StackPanel>
                </Border>
                
                <Border Grid.Column="2" Background="#FDEDEC" CornerRadius="15" Padding="15" Margin="10">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="📋" FontSize="36"/>
                        <TextBlock x:Name="txtActiveLoans" Text="0" FontSize="28" FontWeight="Bold"/>
                        <TextBlock Text="активных выдач" FontSize="14" Foreground="#7F8C8D"/>
                    </StackPanel>
                </Border>
                
                <Border Grid.Column="3" Background="#F4ECF7" CornerRadius="15" Padding="15" Margin="10">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="⏰" FontSize="36"/>
                        <TextBlock x:Name="txtOverdue" Text="0" FontSize="28" FontWeight="Bold"/>
                        <TextBlock Text="просрочек" FontSize="14" Foreground="#7F8C8D"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <TabControl Grid.Row="2" Margin="0,0,0,20" FontSize="14">
            <TabItem Header="📚 ВСЕ КНИГИ" Height="40">
                <DataGrid x:Name="dgBooks" AutoGenerateColumns="True" IsReadOnly="True" 
                          Background="White" FontSize="13" RowHeight="35" Margin="5"/>
            </TabItem>
            <TabItem Header="👥 ЧИТАТЕЛИ" Height="40">
                <DataGrid x:Name="dgReaders" AutoGenerateColumns="True" IsReadOnly="True" 
                          Background="White" FontSize="13" RowHeight="35" Margin="5"/>
            </TabItem>
            <TabItem Header="📋 ВСЕ ВЫДАЧИ" Height="40">
                <DataGrid x:Name="dgLoans" AutoGenerateColumns="True" IsReadOnly="True" 
                          Background="White" FontSize="13" RowHeight="35" Margin="5"/>
            </TabItem>
            <TabItem Header="✨ ДОБАВИТЬ КНИГУ" Height="40">
                <StackPanel Margin="30" Width="400">
                    <TextBlock Text="Название книги:" FontSize="15" FontWeight="Bold" Margin="0,10,0,5"/>
                    <TextBox x:Name="txtNewBookTitle" FontSize="14" Height="40" Padding="10" Margin="0,0,0,15"/>
                    
                    <TextBlock Text="Автор:" FontSize="15" FontWeight="Bold" Margin="0,10,0,5"/>
                    <TextBox x:Name="txtNewBookAuthor" FontSize="14" Height="40" Padding="10" Margin="0,0,0,15"/>
                    
                    <TextBlock Text="Количество экземпляров:" FontSize="15" FontWeight="Bold" Margin="0,10,0,5"/>
                    <TextBox x:Name="txtNewBookCopies" Text="1" FontSize="14" Height="40" Padding="10" Margin="0,0,0,25"/>
                    
                    <Button x:Name="btnAddBook" Content="➕ ДОБАВИТЬ КНИГУ" Width="200" Height="50" 
                            FontSize="14" FontWeight="Bold"
                            Background="#2ECC71" Foreground="White" Click="BtnAddBook_Click" Cursor="Hand"
                            HorizontalAlignment="Center"/>
                </StackPanel>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button x:Name="btnReturn" Content="📖 ВЕРНУТЬ КНИГУ" Width="180" Height="55" 
                    FontSize="15" FontWeight="Bold"
                    Background="#E67E22" Foreground="White" Click="BtnReturn_Click" Cursor="Hand" Margin="0,0,10,0"/>
            <Button x:Name="btnRefresh" Content="🔄 ОБНОВИТЬ" Width="160" Height="55" 
                    FontSize="15" FontWeight="Bold"
                    Background="#3498DB" Foreground="White" Click="BtnRefresh_Click" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>